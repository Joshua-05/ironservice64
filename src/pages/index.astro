---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout/index.astro";
import MainBlock from "../components/MainBlock/index.astro";
import Section from "../components/Section/index.astro";
import SectionHeader from "../components/SectionHeader/index.astro";
import ServiceList from "../components/ServiceList/index.astro";
import BrendList from "../widgets/BrendList.astro";

import Testimonials from "../components/Testimonials/index.astro";

import Slider from "../widgets/Slider.astro";
import Advantages from "../widgets/Advantages.astro";

const page = await getEntry("pages", "index");
if (!page) throw new Error("Home page not found");

const { title, description, image, advantages, seo } = page.data;
---

<BaseLayout title={seo.title} description={seo.description}>
	<MainBlock
		badgeText="Лучший сервис по ремонту бытовой техники"
		description={description}
		ctaText="Оставить заявку"
		ctaHref="/contact"
		heading="Iron Service - надежный партнер в ремонте бытовой техники"
		mainBackgroundImage={image}
		property={{
			href: "/services",
			image: "/hero/service2.jpg",
			title: "Наши услуги",
			location: "Саратов",
		}}
	/>
	<Section>
		<SectionHeader
			badgeText="Наши услуги"
			heading="Ремонт любого вида техники"
			paragraph="Недорогой и оперативный ремонт техники любой сложности"
		/>
		<div class="collection-list-wrapper sections w-dyn-list">
			<ServiceList
				services={[
					{
						title: "Ремонт бытовой техники",
						description:
							"Полный спектр услуг по ремонту всех бытовых приборов -- от мелочей до сложной электроники",
						imageUrl: "/hero/repair1.jpg",
						propertyUrl: "/services/household",
					},
					{
						title: "Ремонт компьютерной и цифровой техники",
						description:
							"Диагностика и восстановление ПК, ноутбуков и периферии — любой сложности и любого производителя.",
						imageUrl: "/hero/repair2.jpg",
						propertyUrl: "/services/computer",
					},
					{
						title: "Ремонт климатической техники",
						description:
							"Профессиональный сервис для систем, создающих ваш комфорт — от кондиционеров до вентиляции.",
						imageUrl: "/hero/repair3.jpg",
						propertyUrl: "/services/climatic",
					},
					{
						title: "Ремонт оргтехники",
						description:
							"Оперативный ремонт принтеров, МФУ и копиров — чтобы ваш офис работал без остановок.",
						imageUrl: "/image/services/printer.jpg",
						propertyUrl: "/services/office",
					},
				]}
			/>
		</div>
		<a href="/services" class="button w-button">Все услуги</a>
	</Section>
	<div id="about-section"></div>
	<Section>
		<SectionHeader
			heading="О КОМПАНИИ"
			paragraph="Выезд на ремонт крупной бытовой техники ежедневно. Работаем по Саратову и Энгельсу."
		/>
		<div class="grid _2">
			<Slider />
			<Advantages />
		</div>
	</Section>
	<Section>
		<SectionHeader
			heading="БРЕНДЫ"
			paragraph="Оригинальные запчасти под любой бренд"
		/>
		<BrendList />
	</Section>
	<Section>
		<Testimonials />
	</Section>
</BaseLayout>
